    "lucide-react": ">=0.400"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "lucide-react": "^0.460.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
